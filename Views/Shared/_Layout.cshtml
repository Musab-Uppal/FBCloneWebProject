<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookFace</title>
    <!-- Add this in the head section -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 with Dark Theme -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom Theme CSS -->
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var isAuthPage = requestPath.IndexOf("/Identity/Account/Login", StringComparison.OrdinalIgnoreCase) >= 0
                     || requestPath.IndexOf("/Account/Login", StringComparison.OrdinalIgnoreCase) >= 0
                     || requestPath.IndexOf("/Identity/Account/Register", StringComparison.OrdinalIgnoreCase) >= 0
                     || requestPath.IndexOf("/Account/Register", StringComparison.OrdinalIgnoreCase) >= 0;
}
<body class="app-shell @(isAuthPage ? "identity-auth-page" : "")">
    <div id="globalPageLoader" class="global-page-loader">
        <div class="loader-orbit" aria-hidden="true">
            <span class="loader-ring loader-ring-one"></span>
            <span class="loader-ring loader-ring-two"></span>
            <span class="loader-core"></span>
        </div>
        <p class="loader-label">Loading BookFace</p>
    </div>

    <!-- Include Header -->
    <!-- Add the notification partial in your navbar where you want notifications to appear -->
   
    @await Html.PartialAsync("_Header")

    <!-- Main Content -->
    <main role="main" class="main-content">
        @RenderBody()
    </main>

    <!-- Footer removed per request -->

    <button type="button" id="backToTop" class="back-to-top" aria-label="Back to top">
        <i class="bi bi-arrow-up"></i>
    </button>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>