@model List<Notification>

@if (Model == null || !Model.Any())
{
    <div class="notification-empty">
        <i class="bi bi-bell-slash"></i>
        <p>No notifications yet</p>
        <small class="text-muted">When you get notifications, they'll show up here</small>
    </div>
}
else
{
    foreach (var notification in Model)
    {
        <div class="notification-item @(!notification.IsRead ? "unread" : "")"
             data-notification-id="@notification.Id"
             data-action-url="@notification.ActionUrl">
            <div class="notification-item-content">
                <div class="notification-icon @notification.Type.ToString().ToLower()">
                    @{
                        var iconClass = notification.Type switch
                        {
                            NotificationType.Follow => "bi-person-plus",
                            NotificationType.Like => "bi-heart",
                            NotificationType.Comment => "bi-chat",
                            NotificationType.GroupJoin => "bi-people",
                            NotificationType.PostShare => "bi-share",
                            _ => "bi-bell"
                        };
                    }
                    <i class="bi @iconClass"></i>
                </div>
                <div class="notification-details">
                    <p>@notification.Message</p>
                    <div class="notification-time">
                        <i class="bi bi-clock"></i> @notification.CreatedAt.ToString("MMM dd, hh:mm tt")
                    </div>
                </div>
            </div>
        </div>
    }
}