@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<header class="header">
    <!-- Top Navigation Bar -->
    <nav class="navbar navbar-expand-lg main-navbar">
        <div class="container-fluid">
            <!-- Logo -->
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <div class="logo">
                    <svg class="logo-icon" width="32" height="32" viewBox="0 0 32 32">
                        <defs>
                            <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#1f7ae0;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#0f9c92;stop-opacity:1" />
                            </linearGradient>
                        </defs>
                        <path d="M16 2C8.268 2 2 8.268 2 16s6.268 14 14 14 14-6.268 14-14S23.732 2 16 2zm0 4c2.21 0 4 1.79 4 4s-1.79 4-4 4-4-1.79-4-4 1.79-4 4-4zm8 18c-1.67-2.26-4.14-4-8-4-3.86 0-6.33 1.74-8 4v-2c0-3.31 3.58-6 8-6s8 2.69 8 6v2z"
                              fill="url(#logoGradient)" />
                    </svg>
                    <span class="logo-text">
                        BookFace
                    </span>
                </div>
            </a>

            <!-- Mobile Toggle Button -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon">
                    <i class="bi bi-list"></i>
                </span>
            </button>

            <!-- Navigation Content -->
            <div class="collapse navbar-collapse" id="navbarMain">
                <!-- Search Bar (Centered) -->
                @if (SignInManager.IsSignedIn(User))
                {
                    <div class="navbar-search mx-auto">
                        <form asp-controller="Search" asp-action="Index" method="get" class="search-form">
                            <div class="search-container">
                                <i class="bi bi-search search-icon"></i>
                                <input type="text" name="q" class="search-input"
                                       placeholder="Search posts, people, groups..."
                                       autocomplete="off" id="globalSearch">
                                <button type="submit" class="search-btn">
                                    <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </form>
                        <!-- Quick Search Results -->
                        <div class="quick-search-results" id="quickSearchResults"></div>
                    </div>
                }

                <!-- Navigation Menu -->
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <!-- Home -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Feed"
                               data-bs-toggle="tooltip" title="Home">
                                <div class="nav-icon-container">
                                    <i class="bi bi-house-door"></i>
                                </div>
                            </a>
                        </li>

                        <!-- Discover -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Search" asp-action="Discover"
                               data-bs-toggle="tooltip" title="Discover">
                                <div class="nav-icon-container">
                                    <i class="bi bi-compass"></i>
                                </div>
                            </a>
                        </li>

                        <!-- Groups -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Groups" asp-action="Index"
                               data-bs-toggle="tooltip" title="Groups">
                                <div class="nav-icon-container">
                                    <i class="bi bi-people"></i>
                                    @if (ViewBag.GroupNotificationCount > 0)
                                    {
                                        <span class="nav-badge">@ViewBag.GroupNotificationCount</span>
                                    }
                                </div>
                            </a>
                        </li>

                        <!-- Notifications -->
                        <li class="nav-item dropdown notification-dropdown">
                            <a class="nav-link " href="#" id="notificationsDropdown"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false"
                               data-bs-toggle="tooltip" title="Notifications">
                                <div class="nav-icon-container">
                                    <i class="bi bi-bell"></i>
                                    @if (ViewBag.UnreadNotificationCount > 0)
                                    {
                                        <span class="nav-badge" id="notificationBadge">@ViewBag.UnreadNotificationCount</span>
                                    }
                                    else
                                    {
                                        <span class="nav-badge" id="notificationBadge" style="display: none;">0</span>
                                    }
                                </div>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end notification-dropdown-menu"
                                 aria-labelledby="notificationsDropdown">
                                <div class="notification-header">
                                    <h6>Notifications</h6>
                                    @if (ViewBag.UnreadNotificationCount > 0)
                                    {
                                        <form asp-controller="Notification" asp-action="MarkAllAsRead" method="post" id="markAllAsReadForm">
                                            <button type="submit" class="btn-mark-all">Clear all</button>
                                        </form>
                                    }
                                </div>
                                <div class="notification-list" id="notificationList">
                                    <!-- Notifications will be loaded dynamically -->
                                    <div class="notification-item loading">
                                        <div class="spinner-border spinner-border-sm" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="notification-footer">
                                    <a asp-controller="Notification" asp-action="Index" class="view-all-link">
                                        View all notifications
                                    </a>
                                </div>
                            </div>
                        </li>

                        <!-- Create Post Button -->
                        <li class="nav-item ms-2">
                            <button class="btn-create" data-bs-toggle="modal" data-bs-target="#createPostModal">
                                <i class="bi bi-plus-lg"></i> Create
                            </button>
                        </li>

                        <!-- User Profile -->
                        <li class="nav-item dropdown user-dropdown ms-2">
                            <a class="user-profile-link" href="#" id="userDropdown"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="user-avatar">
                                    @if (User.Identity?.Name != null)
                                    {
                                        <span class="avatar-text">
                                            @User.Identity.Name.Substring(0, 1).ToUpper()
                                        </span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-person"></i>
                                    }
                                </div>
                                <i class="bi bi-chevron-down dropdown-arrow"></i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end user-dropdown-menu"
                                 aria-labelledby="userDropdown">
                                <div class="user-info">
                                    <div class="user-avatar-lg">
                                        @if (User.Identity?.Name != null)
                                        {
                                            <span class="avatar-text-lg">
                                                @User.Identity.Name.Substring(0, 1).ToUpper()
                                            </span>
                                        }
                                    </div>
                                    <div class="user-details">
                                        <h6>@User.Identity?.Name</h6>
                                        <small>View your profile</small>
                                    </div>
                                </div>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-controller="Profile" asp-action="View">
                                    <i class="bi bi-person-circle"></i> My Profile
                                </a>
                                <a class="dropdown-item" asp-controller="Follow" asp-action="Followers">
                                    <i class="bi bi-people"></i> Followers
                                </a>
                                <a class="dropdown-item" asp-controller="Follow" asp-action="Following">
                                    <i class="bi bi-person-check"></i> Following
                                </a>
                                <a class="dropdown-item" asp-controller="Notification" asp-action="Index">
                                    <i class="bi bi-bell"></i> Notifications
                                    <span class="badge bg-primary ms-1" id="notificationCountBadge">
                                        @(ViewBag.UnreadNotificationCount > 0 ? ViewBag.UnreadNotificationCount.ToString() : "")
                                    </span>
                                </a>
                                <div class="dropdown-divider"></div>
                                <form class="dropdown-item-form" asp-area="Identity" asp-page="/Account/Logout"
                                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                    <button type="submit" class="dropdown-item logout-btn">
                                        <i class="bi bi-box-arrow-right"></i> Log Out
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <!-- For Non-logged in users -->
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                Sign In
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-primary btn-signup" asp-area="Identity" asp-page="/Account/Register">
                                Get Started
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<!-- Create Post Modal -->
@if (SignInManager.IsSignedIn(User))
{
    <div class="modal fade" id="createPostModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square"></i> Create Post
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-controller="Home" asp-action="CreatePost" method="post" enctype="multipart/form-data" id="ajaxCreatePostForm">
                    <div class="modal-body">
                        <div class="post-creator">
                            <!-- User Info -->
                            <div class="creator-info">
                                <div class="creator-avatar">
                                    @if (User.Identity?.Name != null)
                                    {
                                        <span class="avatar-text-sm">
                                            @User.Identity.Name.Substring(0, 1).ToUpper()
                                        </span>
                                    }
                                </div>
                                <div>
                                    <h6>@User.Identity?.Name</h6>
                                    <select class="form-select form-select-sm w-auto d-inline-block">
                                        <option selected>Public</option>
                                        <option>Friends</option>
                                        <option>Only Me</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Content Area -->
                            <div class="content-area mt-3">
                                <textarea name="content" class="form-control post-content"
                                      rows="3" placeholder="What's on your mind?"
                                      required></textarea>
                            </div>

                            <!-- Post Options -->
                            <div class="post-options mt-3">
                                <div class="options-title">Add to your post</div>
                                <div class="options-grid">
                                    <label class="option-item">
                                        <input type="file" name="image" class="d-none" accept="image/*,video/*">
                                        <i class="bi bi-image"></i>
                                        <span>Photo/Video</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send"></i> Post
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (SignInManager.IsSignedIn(User))
{
    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>
    <script>
        // Initialize SignalR connection for real-time notifications
        document.addEventListener('DOMContentLoaded', function() {
            initializeSignalR();
            loadNotifications();
            setupNotificationEvents();
        });

        let signalRConnection;

        async function initializeSignalR() {
            try {
                signalRConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                    .build();

                // Handle incoming notifications
                signalRConnection.on("ReceiveNotification", (notification) => {
                    console.log("New notification received:", notification);

                    // Update notification badge
                    updateNotificationBadge();

                    // Show toast notification
                    showNotificationToast(notification);

                    // Add to notification dropdown
                    addNotificationToDropdown(notification);

                    // Update notification count in user dropdown
                    updateNotificationCount();
                });

                // Handle connection events
                signalRConnection.onreconnecting((error) => {
                    console.log('SignalR reconnecting due to error:', error);
                });

                signalRConnection.onreconnected((connectionId) => {
                    console.log('SignalR reconnected with connection ID:', connectionId);
                });

                signalRConnection.onclose((error) => {
                    console.log('SignalR connection closed:', error);
                    // Try to reconnect after 5 seconds
                    setTimeout(initializeSignalR, 5000);
                });

                // Start the connection
                await signalRConnection.start();
                console.log("SignalR connected successfully");

            } catch (err) {
                console.error("SignalR connection error:", err);
                // Retry after 5 seconds
                setTimeout(initializeSignalR, 5000);
            }
        }

        // Update notification badge count
        async function updateNotificationBadge() {
            try {
                const response = await fetch('/Notification/GetUnreadCount');
                if (response.ok) {
                    const data = await response.json();
                    const badge = document.getElementById('notificationBadge');
                    if (badge) {
                        badge.textContent = data.count;
                        if (data.count > 0) {
                            badge.style.display = 'inline';
                            badge.classList.add('pulse');
                            setTimeout(() => badge.classList.remove('pulse'), 1000);
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                }
            } catch (error) {
                console.error('Error updating badge:', error);
            }
        }

        // Update notification count in user dropdown
        async function updateNotificationCount() {
            try {
                const response = await fetch('/Notification/GetUnreadCount');
                if (response.ok) {
                    const data = await response.json();
                    const countBadge = document.getElementById('notificationCountBadge');
                    if (countBadge) {
                        if (data.count > 0) {
                            countBadge.textContent = data.count;
                            countBadge.style.display = 'inline';
                        } else {
                            countBadge.style.display = 'none';
                        }
                    }
                }
            } catch (error) {
                console.error('Error updating notification count:', error);
            }
        }

        // Load notifications into dropdown
        async function loadNotifications() {
            try {
                const notificationList = document.getElementById('notificationList');
                if (!notificationList) return;

                const response = await fetch('/Notification/GetLatest');
                if (response.ok) {
                    const html = await response.text();
                    notificationList.innerHTML = html;
                }
            } catch (error) {
                console.error('Error loading notifications:', error);
            }
        }

        // Add new notification to dropdown
        function addNotificationToDropdown(notification) {
            const notificationList = document.getElementById('notificationList');
            if (!notificationList) return;

            // Remove loading spinner if present
            const loadingItem = notificationList.querySelector('.notification-item.loading');
            if (loadingItem) {
                loadingItem.remove();
            }

            // Create new notification item
            const notificationItem = document.createElement('div');
            notificationItem.className = 'notification-item unread';
            notificationItem.innerHTML = `
                <div class="notification-icon">
                    <i class="bi bi-${getNotificationIcon(notification.type)} text-${getNotificationColor(notification.type)}"></i>
                </div>
                <div class="notification-content">
                    <div class="notification-message">${notification.message}</div>
                    <small class="notification-time">${notification.createdAt}</small>
                </div>
                <form action="/Notification/MarkAsRead" method="post" class="d-inline mark-as-read-form">
                    <input type="hidden" name="notificationId" value="${notification.id}" />
                    <button type="submit" class="btn-mark-read" title="Mark as read">
                        <i class="bi bi-check2"></i>
                    </button>
                </form>
            `;

            // Add to top of list
            if (notificationList.firstChild) {
                notificationList.insertBefore(notificationItem, notificationList.firstChild);
            } else {
                notificationList.appendChild(notificationItem);
            }

            // Limit to 5 items
            const items = notificationList.querySelectorAll('.notification-item:not(.empty)');
            if (items.length > 5) {
                items[items.length - 1].remove();
            }
        }

        // Show toast notification
        function showNotificationToast(notification) {
            // Create toast element
            const toastHtml = `
                <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055">
                    <div class="toast show notification-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="5000">
                        <div class="toast-header bg-${getNotificationColor(notification.type)} text-white">
                            <i class="bi bi-${getNotificationIcon(notification.type)} me-2"></i>
                            <strong class="me-auto">${getNotificationTitle(notification.type)}</strong>
                            <small>${notification.createdAt}</small>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                        <div class="toast-body">
                            ${notification.message}
                            ${notification.actionUrl ? `
                                <div class="mt-2">
                                    <a href="${notification.actionUrl}" class="btn btn-sm btn-outline-${getNotificationColor(notification.type)}">
                                        View
                                    </a>
                                    <form action="/Notification/MarkAsRead" method="post" class="d-inline ms-1">
                                        <input type="hidden" name="notificationId" value="${notification.id}" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                                            Mark as read
                                        </button>
                                    </form>
                                </div>
                            ` : ''}
                        </div>
                    </div>
                </div>
            `;

            // Add toast to page
            const toastContainer = document.createElement('div');
            toastContainer.innerHTML = toastHtml;
            document.body.appendChild(toastContainer);

            // Initialize Bootstrap toast
            const toastElement = toastContainer.querySelector('.toast');
            const toast = new bootstrap.Toast(toastElement);
            toast.show();

            // Remove toast from DOM after it's hidden
            toastElement.addEventListener('hidden.bs.toast', function() {
                toastContainer.remove();
            });
        }

        // Helper functions for notifications
        function getNotificationIcon(type) {
            switch(type) {
                case 'like': return 'hand-thumbs-up';
                case 'follow': return 'person-plus';
                case 'comment': return 'chat-text';
                case 'groupjoin': return 'people';
                case 'postshare': return 'share';
                default: return 'bell';
            }
        }

        function getNotificationColor(type) {
            switch(type) {
                case 'like': return 'primary';
                case 'follow': return 'success';
                case 'comment': return 'info';
                case 'groupjoin': return 'warning';
                case 'postshare': return 'secondary';
                default: return 'dark';
            }
        }

        function getNotificationTitle(type) {
            switch(type) {
                case 'like': return 'New Like';
                case 'follow': return 'New Follower';
                case 'comment': return 'New Comment';
                case 'groupjoin': return 'Group Activity';
                case 'postshare': return 'Post Shared';
                default: return 'Notification';
            }
        }

        // Setup notification-related event listeners
        function setupNotificationEvents() {
            // Mark all as read form
            const markAllForm = document.getElementById('markAllAsReadForm');
            if (markAllForm) {
                markAllForm.addEventListener('submit', async function(e) {
                    e.preventDefault();

                    try {
                        const response = await fetch('/Notification/MarkAllAsRead', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            }
                        });

                        if (response.ok) {
                            const data = await response.json();
                            console.log(`Marked ${data.markedCount} notifications as read`);

                            // Update UI
                            updateNotificationBadge();
                            updateNotificationCount();

                            // Reload notifications
                            loadNotifications();
                        }
                    } catch (error) {
                        console.error('Error marking all as read:', error);
                    }
                });
            }

            // Delegate mark-as-read form submissions
            document.addEventListener('submit', function(e) {
                if (e.target.classList.contains('mark-as-read-form')) {
                    e.preventDefault();

                    const form = e.target;
                    const formData = new FormData(form);

                    fetch(form.action, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (response.ok) {
                            // Update the notification item
                            const notificationItem = form.closest('.notification-item');
                            if (notificationItem) {
                                notificationItem.classList.remove('unread');
                                notificationItem.classList.add('read');
                                form.remove();
                            }

                            // Update badge and count
                            updateNotificationBadge();
                            updateNotificationCount();
                        }
                    })
                    .catch(error => console.error('Error marking as read:', error));
                }
            });

            // Check for new notifications every 30 seconds
            setInterval(updateNotificationBadge, 30000);
        }
    </script>
}