@model List<semproject.Models.Group>
@{
    ViewData["Title"] = "My Groups";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Groups</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create Group
        </a>
    </div>

    <div class="row">
        <!-- Your Groups -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-people-fill"></i> Groups You've Joined
                        <span class="badge bg-primary">@Model.Count</span>
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="row">
                            @foreach (var group in Model)
                            {
                                <div class="col-md-6 mb-4">
                                    <div class="card h-100 border">
                                        @if (!string.IsNullOrEmpty(group.CoverImageUrl))
                                        {
                                            <img src="@group.CoverImageUrl" class="card-img-top" alt="@group.Name" style="height: 150px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                                                 style="height: 150px;">
                                                <i class="bi bi-people-fill text-white" style="font-size: 48px;"></i>
                                            </div>
                                        }

                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h5 class="card-title mb-1">@group.Name</h5>
                                                @if (group.IsPrivate)
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="bi bi-lock"></i> Private
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-globe"></i> Public
                                                    </span>
                                                }
                                            </div>

                                            <p class="card-text text-muted small mb-3">
                                                @if (group.Description.Length > 100)
                                                {
                                                    @group.Description.Substring(0, 100)
                                        
                                                    <text>...</text>
                                                }
                                                else
                                                {
                                                    @group.Description
                                                }
                                            </p>

                                            <div class="d-flex justify-content-between align-items-center">
                                                <small class="text-muted">
                                                    <i class="bi bi-people"></i> @group.Members.Count members
                                                </small>
                                                <div>
                                                    <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-eye"></i> View
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <i class="bi bi-people text-muted" style="font-size: 64px;"></i>
                            </div>
                            <h4>No groups yet</h4>
                            <p class="text-muted mb-4">You haven't joined any groups yet. Join a public group or create your own!</p>
                            <a asp-action="Browse" class="btn btn-primary">
                                <i class="bi bi-compass"></i> Browse Public Groups
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Quick Actions -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-lightning-charge"></i> Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Create New Group
                        </a>
                        
                        
                    </div>
                </div>
            </div>

            <!-- Group Statistics -->
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-graph-up"></i> Group Stats</h6>
                </div>
                <div class="card-body">
                    <div class="text-center">
                        <h1 class="display-4">@Model.Count</h1>
                        <p class="text-muted">Total Groups</p>
                    </div>

                    <hr>

                    <div class="row text-center">
                        <div class="col-6">
                            <h4>@Model.Count(g => !g.IsPrivate)</h4>
                            <small class="text-muted">Public Groups</small>
                        </div>
                        <div class="col-6">
                            <h4>@Model.Count(g => g.IsPrivate)</h4>
                            <small class="text-muted">Private Groups</small>
                        </div>
                    </div>

                    @if (Model.Any())
                    {
                        <hr>
                        <h6>Recent Activity</h6>
                        <ul class="list-unstyled mb-0">
                            @foreach (var group in Model.OrderByDescending(g => g.CreatedAt).Take(3))
                            {
                                <li class="mb-2">
                                    <small class="text-muted">@group.CreatedAt.ToString("MMM dd")</small><br>
                                    <strong>@group.Name</strong>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>