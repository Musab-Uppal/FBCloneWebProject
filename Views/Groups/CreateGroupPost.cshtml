@model semproject.Models.Group
@{
    ViewData["Title"] = "Create Group Post";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Create Post in @Model.Name
                    </h5>
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-action="Details"
                       asp-route-id="@Model.Id">
                        <i class="bi bi-arrow-left"></i> Back to Group
                    </a>
                </div>
                <div class="card-body">
                    <form asp-action="SubmitGroupPostFromView"
                          asp-controller="Groups"
                          method="post"
                          enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="groupId" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label" for="content">Post Content</label>
                            <textarea id="content"
                                      name="content"
                                      class="form-control"
                                      rows="6"
                                      placeholder="What would you like to share with the group?"
                                      required></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="image">Image (optional)</label>
                            <input id="image" type="file" name="image" class="form-control" accept="image/*">
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a class="btn btn-secondary"
                               asp-action="Details"
                               asp-route-id="@Model.Id">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> Post to Group
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
