@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg animate__animated animate__fadeIn">
                <div class="card-header bg-primary text-white py-4">
                    <h1 class="card-title mb-0"><i class="bi bi-shield-check me-2"></i>@ViewData["Title"]</h1>
                </div>
                <div class="card-body p-5">
                    <div class="privacy-content">
                        <div class="mb-5">
                            <h3 class="text-primary mb-3"><i class="bi bi-house-door me-2"></i>Information Collection</h3>
                            <p>We collect information to provide better services to all our users. This includes:</p>
                            <ul class="list-group list-group-flush bg-transparent">
                                <li class="list-group-item border-0 px-0">
                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                    Information you provide directly
                                </li>
                                <li class="list-group-item border-0 px-0">
                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                    Information from your use of our services
                                </li>
                                <li class="list-group-item border-0 px-0">
                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                    Information from third-party sources
                                </li>
                            </ul>
                        </div>

                        <div class="mb-5">
                            <h3 class="text-primary mb-3"><i class="bi bi-lock me-2"></i>How We Use Information</h3>
                            <p>We use the information we collect to provide, maintain, and improve our services, to develop new ones, and to protect BookFace and our users.</p>
                            <div class="row mt-4">
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100 border-0 bg-light">
                                        <div class="card-body">
                                            <i class="bi bi-gear text-primary fs-1 mb-3"></i>
                                            <h5>Service Improvement</h5>
                                            <p class="text-muted">Enhancing user experience and functionality</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100 border-0 bg-light">
                                        <div class="card-body">
                                            <i class="bi bi-shield text-primary fs-1 mb-3"></i>
                                            <h5>Security</h5>
                                            <p class="text-muted">Protecting against unauthorized access</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-5">
                            <h3 class="text-primary mb-3"><i class="bi bi-share me-2"></i>Information Sharing</h3>
                            <p>We do not share personal information with companies, organizations, or individuals outside of BookFace except in the following cases:</p>
                            <div class="alert alert-info animate__animated animate__pulse animate__infinite animate__slower">
                                <i class="bi bi-info-circle me-2"></i>
                                Your information is never sold to third parties
                            </div>
                        </div>

                        <div class="mb-5">
                            <h3 class="text-primary mb-3"><i class="bi bi-calendar-check me-2"></i>Data Retention</h3>
                            <p>We retain the information we collect for as long as necessary to provide our services and for legitimate business purposes.</p>
                        </div>

                        

                        <div class="mb-4">
                            <h3 class="text-primary mb-3"><i class="bi bi-telephone me-2"></i>Contact Us</h3>
                            <p>If you have questions about this Privacy Policy, please contact us at:</p>
                            <div class="card bg-light">
                                <div class="card-body">
                                    <p class="mb-1"><i class="bi bi-envelope me-2"></i>privacy@bookface.com</p>
                                    <p class="mb-0"><i class="bi bi-clock me-2"></i>Response time: 24-48 hours</p>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning mt-5 animate__animated animate__shakeX animate__delay-2s">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>Last Updated:</strong> @DateTime.Now.ToString("MMMM dd, yyyy")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

