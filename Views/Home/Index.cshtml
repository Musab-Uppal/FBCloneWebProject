@{
    ViewData["Title"] = "Welcome to BookFace";
}

<div class="container mt-5">
    <div class="row align-items-center min-vh-75">
        <div class="col-lg-6">
            <div class="animate__animated animate__fadeInLeft">
                <h1 class="display-4 fw-bold text-gradient mb-4">Welcome to <span class="text-primary">BookFace</span></h1>
                <p class="lead mb-4">Connect with friends, share moments, and discover communities that matter to you.</p>

                <div class="features mb-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-start mb-3">
                                <div class="feature-icon me-3">
                                    <i class="bi bi-chat-dots text-primary fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1">Share & Connect</h5>
                                    <p class="text-muted small mb-0">Share moments with friends</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-start mb-3">
                                <div class="feature-icon me-3">
                                    <i class="bi bi-people text-success fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1">Join Communities</h5>
                                    <p class="text-muted small mb-0">Find groups that match your interests</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-start mb-3">
                                <div class="feature-icon me-3">
                                    <i class="bi bi-bell text-warning fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1">Real-time Updates</h5>
                                    <p class="text-muted small mb-0">Stay updated instantly</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-start mb-3">
                                <div class="feature-icon me-3">
                                    <i class="bi bi-shield-check text-info fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1">Safe & Secure</h5>
                                    <p class="text-muted small mb-0">Your privacy is our priority</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="stats d-flex gap-4 mb-4">
                    <div class="text-center">
                        <h3 class="text-primary mb-0 animate-count" data-count="1000">0</h3>
                        <small class="text-muted">Active Users</small>
                    </div>
                    <div class="text-center">
                        <h3 class="text-success mb-0 animate-count" data-count="500">0</h3>
                        <small class="text-muted">Communities</small>
                    </div>
                    <div class="text-center">
                        <h3 class="text-warning mb-0 animate-count" data-count="10000">0</h3>
                        <small class="text-muted">Posts Shared</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-lg animate__animated animate__fadeInRight animate__delay-1s">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="avatar-circle mx-auto mb-3">
                            <i class="bi bi-person-circle fs-1 text-white"></i>
                        </div>
                        <h2 class="card-title">Get Started</h2>
                        <p class="text-muted">Join our growing community today</p>
                    </div>

                    @if (!User.Identity.IsAuthenticated)
                    {
                        <div class="d-grid gap-3">
                            <a class="btn btn-primary btn-lg btn-gradient py-3 animate__animated animate__pulse animate__infinite animate__slower"
                               asp-area="Identity" asp-page="/Account/Register">
                                <i class="bi bi-person-plus me-2"></i>Create New Account
                            </a>

                            <div class="divider d-flex align-items-center my-3">
                                <p class="text-center mx-3 mb-0 text-muted">or</p>
                            </div>

                            <a class="btn btn-outline-primary btn-lg py-3"
                               asp-area="Identity" asp-page="/Account/Login">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Login to Existing Account
                            </a>
                        </div>

                        
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <div class="mb-3">
                                <div class="avatar-circle mx-auto mb-3">
                                    <span class="avatar-text">@User.Identity.Name.Substring(0, 1).ToUpper()</span>
                                </div>
                                <h4>Welcome back, @User.Identity.Name!</h4>
                                <p class="text-muted">Ready to connect with your community?</p>
                            </div>

                            <div class="d-grid gap-2">
                                <a class="btn btn-primary btn-lg btn-gradient"
                                   asp-controller="Home" asp-action="Feed">
                                    <i class="bi bi-house-door me-2"></i>Go to Your Feed
                                </a>
                                <a class="btn btn-outline-primary"
                                   asp-controller="Groups" asp-action="Index">
                                    <i class="bi bi-people me-2"></i>Explore Groups
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Links -->
            <div class="row mt-4 g-2">
                <div class="col-md-4">
                    <div class="card border-0 bg-light h-100 text-center p-3 quick-link" data-url="/Groups">
                        <i class="bi bi-people fs-4 text-primary mb-2"></i>
                        <h6 class="mb-0">Groups</h6>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 bg-light h-100 text-center p-3 quick-link" data-url="/Search/Discover">
                        <i class="bi bi-compass fs-4 text-success mb-2"></i>
                        <h6 class="mb-0">Discover</h6>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 bg-light h-100 text-center p-3 quick-link" data-url="/Home/Privacy">
                        <i class="bi bi-shield-check fs-4 text-info mb-2"></i>
                        <h6 class="mb-0">Privacy</h6>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Animated counter
        document.addEventListener('DOMContentLoaded', function() {
            const counters = document.querySelectorAll('.animate-count');

            counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-count'));
                const duration = 2000;
                const step = target / (duration / 16);
                let current = 0;

                const updateCounter = () => {
                    current += step;
                    if (current < target) {
                        counter.textContent = Math.floor(current);
                        requestAnimationFrame(updateCounter);
                    } else {
                        counter.textContent = target;
                    }
                };

                setTimeout(updateCounter, 500);
            });

            // Quick link hover effects
            document.querySelectorAll('.quick-link').forEach(link => {
                link.addEventListener('click', function() {
                    window.location.href = this.getAttribute('data-url');
                });
            });
        });
    </script>
}