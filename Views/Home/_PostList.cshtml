@model List<semproject.Models.Post>
@{ var likedPostIds = ViewBag.LikedPostIds as List<int> ?? new List<int>();
    var postLikes = ViewBag.PostLikes as Dictionary<int,int> ?? new Dictionary<int,int>();
    var currentUserId = ViewBag.CurrentUserId as string; }

@foreach (var post in Model)
{
    var isLiked = likedPostIds.Contains(post.Id);
    var likeCount = postLikes.ContainsKey(post.Id) ? postLikes[post.Id] : (post.Likes?.Count ?? 0);
    var commentCount = post.Comments?.Count ?? 0;

    <div class="card mb-4 post-card" id="post-@post.Id" data-post-id="@post.Id">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5 class="card-title mb-1">@post.User.UserName</h5>
                    <small class="text-muted">
                        @post.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")
                        <span class="post-time-ago">(@post.CreatedAt)</span>
                    </small>
                </div>
            </div>

            <p class="card-text">@post.Content</p>

            @if (!string.IsNullOrEmpty(post.ImageUrl))
            {
                <img src="@post.ImageUrl" class="img-fluid rounded mb-3" alt="Post image">
            }

            <div class="d-flex justify-content-between align-items-center">
                <button type="button"
                        class="btn btn-sm like-btn @(isLiked ? "btn-primary" : "btn-outline-primary")"
                        data-post-id="@post.Id">
                    <i class="bi @(isLiked ? "bi-hand-thumbs-up-fill" : "bi-hand-thumbs-up")"></i>
                    <span class="like-text">@(isLiked ? "Liked" : "Like")</span>
                    <span class="like-count-badge">@likeCount</span>
                </button>

                <span class="text-muted comments-count" data-post-id="@post.Id">
                    <i class="bi bi-chat"></i> <span class="comment-count-number">@commentCount</span> comments
                </span>
            </div>

            <div class="mt-3 comments-section" data-post-id="@post.Id">
                <div class="comments-list">
                    @if (post.Comments != null && post.Comments.Any())
                    {
                        foreach (var comment in post.Comments.OrderByDescending(c => c.CreatedAt).Take(3))
                        {
                            <div class="mb-2 comment-item" data-comment-id="@comment.Id">
                                <div class="d-flex align-items-start">
                                    <div class="me-2">
                                        <i class="bi bi-person-circle"></i>
                                    </div>
                                    <div>
                                        <strong>@comment.User.UserName</strong>
                                        <p class="mb-1 comment-content">@comment.Content</p>
                                        <small class="text-muted comment-time">@comment.CreatedAt.ToString("MMM dd, hh:mm tt")</small>
                                    </div>
                                </div>
                            </div>
                        }

                        if (post.Comments.Count > 3)
                        {
                            <a href="#" class="text-decoration-none view-all-comments" data-post-id="@post.Id">
                                View all @post.Comments.Count comments
                            </a>
                        }
                    }
                    else
                    {
                        <p class="text-muted small mb-2 no-comments-text">No comments yet. Be the first to comment!</p>
                    }
                </div>

                <form class="mt-2 add-comment-form" data-post-id="@post.Id">
                    @Html.AntiForgeryToken()
                    <div class="input-group">
                        <input type="text" name="commentContent" class="form-control comment-input"
                               placeholder="Write a comment..." required>
                        <button class="btn btn-outline-primary" type="submit">Post</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
