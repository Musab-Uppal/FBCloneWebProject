@model List<semproject.Models.Post>
@{
    ViewData["Title"] = "Feed";

    // Get liked post IDs and like counts from ViewBag
    var likedPostIds = ViewBag.LikedPostIds as List<int> ?? new List<int>();
    var postLikes = ViewBag.PostLikes as Dictionary<int, int> ?? new Dictionary<int, int>();
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <!-- Create Post Form -->
            <div class="card mb-4">
                <div class="card-body">
                    <form id="createPostForm" asp-action="CreatePost" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <textarea name="content" class="form-control" rows="3"
                                      placeholder="What's on your mind?" required></textarea>
                        </div>
                        <div class="mb-3">
                            <input type="file" name="image" class="form-control" accept="image/*" />
                        </div>
                        <button type="submit" class="btn btn-primary">Post</button>
                    </form>
                </div>
            </div>

            <!-- Posts Feed -->
            <div id="postsContainer">
                @foreach (var post in Model)
                {
                    var isLiked = likedPostIds.Contains(post.Id);
                    var likeCount = postLikes.ContainsKey(post.Id) ? postLikes[post.Id] : (post.Likes?.Count ?? 0);
                    var commentCount = post.Comments?.Count ?? 0;

                    <div class="card mb-4 post-card" id="post-@post.Id" data-post-id="@post.Id">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title mb-1">@post.User.UserName</h5>
                                    <small class="text-muted">
                                        @post.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")
                                        <span class="post-time-ago">(@post.CreatedAt)</span>
                                    </small>
                                </div>
                            </div>

                            <p class="card-text">@post.Content</p>

                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <img src="@post.ImageUrl" class="img-fluid rounded mb-3" alt="Post image">
                            }

                            <div class="d-flex justify-content-between align-items-center">
                                <!-- Like Button with AJAX -->
                                <button type="button"
                                        class="btn btn-sm like-btn @(isLiked ? "btn-primary" : "btn-outline-primary")"
                                        data-post-id="@post.Id">
                                    <i class="bi @(isLiked ? "bi-hand-thumbs-up-fill" : "bi-hand-thumbs-up")"></i>
                                    <span class="like-text">@(isLiked ? "Liked" : "Like")</span>
                                    <span class="like-count-badge">@likeCount</span>
                                </button>

                                <!-- Comments Count -->
                                <span class="text-muted comments-count" data-post-id="@post.Id">
                                    <i class="bi bi-chat"></i> <span class="comment-count-number">@commentCount</span> comments
                                </span>
                            </div>

                            <!-- Comments Section -->
                            <div class="mt-3 comments-section" data-post-id="@post.Id">
                                <!-- Existing Comments -->
                                <div class="comments-list">
                                    @if (post.Comments != null && post.Comments.Any())
                                    {
                                        foreach (var comment in post.Comments.OrderByDescending(c => c.CreatedAt).Take(3))
                                        {
                                            <div class="mb-2 comment-item" data-comment-id="@comment.Id">
                                                <div class="d-flex align-items-start">
                                                    <div class="me-2">
                                                        <i class="bi bi-person-circle"></i>
                                                    </div>
                                                    <div>
                                                        <strong>@comment.User.UserName</strong>
                                                        <p class="mb-1 comment-content">@comment.Content</p>
                                                        <small class="text-muted comment-time">@comment.CreatedAt.ToString("MMM dd, hh:mm tt")</small>
                                                    </div>
                                                </div>
                                            </div>
                                        }

                                        @if (post.Comments.Count > 3)
                                        {
                                            <a href="#" class="text-decoration-none view-all-comments" data-post-id="@post.Id">
                                                View all @post.Comments.Count comments
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted small mb-2 no-comments-text">No comments yet. Be the first to comment!</p>
                                    }
                                </div>

                                <!-- Add Comment Form with AJAX -->
                                <form class="mt-2 add-comment-form" data-post-id="@post.Id">
                                    @Html.AntiForgeryToken()
                                    <div class="input-group">
                                        <input type="text" name="commentContent" class="form-control comment-input"
                                               placeholder="Write a comment..." required>
                                        <button class="btn btn-outline-primary" type="submit">Post</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="text-center mt-5">
                    <i class="bi bi-newspaper display-1 text-muted"></i>
                    <h4 class="mt-3">No posts yet</h4>
                    <p class="text-muted">Follow some users or create your first post!</p>
                </div>
            }

            <!-- Load More Button -->
            @if (ViewBag.HasMorePosts)
            {
                <div class="text-center mt-4">
                    <button id="loadMoreBtn" class="btn btn-outline-primary" data-page="2" data-seed="@ViewBag.RandomSeed">
                        <i class="bi bi-arrow-down"></i> Load More Posts
                    </button>
                </div>
            }
        </div>

        <!-- Sidebar for Suggestions -->
        <div class="col-md-4 d-none d-md-block">
            <!-- User Stats -->
            <div class="card mb-4">
                <div class="card-body">
                    <h6>Your Stats</h6>
                    <div class="d-flex justify-content-between mt-3">
                        <div class="text-center">
                            <div class="fw-bold">@ViewBag.FollowerCount</div>
                            <small class="text-muted">Followers</small>
                        </div>
                        <div class="text-center">
                            <div class="fw-bold">@ViewBag.FollowingCount</div>
                            <small class="text-muted">Following</small>
                        </div>
                        <div class="text-center">
                            <div class="fw-bold">@Model.Count(p => p.UserId == currentUserId)</div>
                            <small class="text-muted">Posts</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Suggested Users -->
            @if (ViewBag.SuggestedUsers != null && ((List<Microsoft.AspNetCore.Identity.IdentityUser>)ViewBag.SuggestedUsers).Any())
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h6>People you may know</h6>
                        @foreach (var user in ViewBag.SuggestedUsers)
                        {
                            <div class="d-flex align-items-center justify-content-between mb-2 mt-3">
                                <div class="d-flex align-items-center">
                                    <div class="me-2">
                                        <i class="bi bi-person-circle"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold">@user.UserName</div>
                                        <small class="text-muted">@user.Email</small>
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-primary follow-user-btn" data-user-id="@user.Id">
                                    Follow
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Like button functionality with AJAX
            $(document).on('click', '.like-btn', function() {
                const button = $(this);
                const postId = button.data('post-id');
                const likeCountBadge = button.find('.like-count-badge');
                const likeText = button.find('.like-text');
                const icon = button.find('i');

                // Show loading state
                const originalText = likeText.text();
                button.prop('disabled', true);
                likeText.text('...');

                // Send AJAX request
                $.ajax({
                    url: '@Url.Action("LikePost", "Home")',
                    type: 'POST',
                    data: { postId: postId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            // Update button appearance
                            if (response.isLiked) {
                                button.removeClass('btn-outline-primary').addClass('btn-primary');
                                icon.removeClass('bi-hand-thumbs-up').addClass('bi-hand-thumbs-up-fill');
                                likeText.text('Liked');
                            } else {
                                button.removeClass('btn-primary').addClass('btn-outline-primary');
                                icon.removeClass('bi-hand-thumbs-up-fill').addClass('bi-hand-thumbs-up');
                                likeText.text('Like');
                            }

                            // Update like count
                            likeCountBadge.text(response.likeCount);

                            // Add animation effect
                            button.addClass('animate-like');
                            setTimeout(() => {
                                button.removeClass('animate-like');
                            }, 600);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error liking post:', error);
                        showToast('Failed to like post. Please try again.', 'error');
                    },
                    complete: function() {
                        button.prop('disabled', false);
                    }
                });
            });

            // Add comment with AJAX and immediate display
            $(document).on('submit', '.add-comment-form', function(e) {
                e.preventDefault();
                const form = $(this);
                const postId = form.data('post-id');
                const content = form.find('.comment-input').val().trim();
                const commentsList = form.closest('.comments-section').find('.comments-list');
                const commentsCountSpan = $(`.comments-count[data-post-id="${postId}"] .comment-count-number`);
                const noCommentsText = commentsList.find('.no-comments-text');

                if (!content) return;

                // Show loading state
                const submitBtn = form.find('button[type="submit"]');
                submitBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span>');

                $.ajax({
                    url: '@Url.Action("AddComment", "Home")',
                    type: 'POST',
                    data: {
                        postId: postId,
                        content: content
                    },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            // Clear the input
                            form.find('.comment-input').val('');

                            // Create new comment element
                            const now = new Date();
                            const timeString = now.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                            const dateString = now.toLocaleDateString('en-US', {month: 'short', day: 'numeric'});

                            const newCommentHtml = `
                                <div class="mb-2 comment-item" data-comment-id="new">
                                    <div class="d-flex align-items-start">
                                        <div class="me-2">
                                            <i class="bi bi-person-circle"></i>
                                        </div>
                                        <div>
                                            <strong>@User.Identity.Name</strong>
                                            <p class="mb-1 comment-content">${content}</p>
                                            <small class="text-muted comment-time">${dateString}, ${timeString}</small>
                                        </div>
                                    </div>
                                </div>
                            `;

                            // Remove "no comments" text if it exists
                            if (noCommentsText.length) {
                                noCommentsText.remove();
                            }

                            // Add new comment to the top of comments list
                            commentsList.prepend(newCommentHtml);

                            // Update comment count
                            const currentCount = parseInt(commentsCountSpan.text()) || 0;
                            commentsCountSpan.text(currentCount + 1);

                            // Show success message
                            showToast('Comment added successfully!', 'success');

                            // Add fade-in animation to new comment
                            const newComment = commentsList.find('.comment-item').first();
                            newComment.addClass('animate__animated animate__fadeIn');
                            setTimeout(() => {
                                newComment.removeClass('animate__animated animate__fadeIn');
                            }, 1000);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error adding comment:', error);
                        showToast('Failed to add comment. Please try again.', 'error');
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).text('Post');
                    }
                });
            });

            // Follow user with AJAX
            $(document).on('click', '.follow-user-btn', function() {
                const button = $(this);
                const userId = button.data('user-id');

                // Show loading state
                button.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span>');

                $.ajax({
                    url: '@Url.Action("FollowUser", "Home")',
                    type: 'POST',
                    data: { targetUserId: userId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            if (response.isFollowing) {
                                button.text('Following').removeClass('btn-primary').addClass('btn-secondary');
                            } else {
                                button.text('Follow').removeClass('btn-secondary').addClass('btn-primary');
                            }

                            showToast(response.isFollowing ? 'You are now following this user!' : 'You unfollowed this user.', 'success');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error following user:', error);
                        showToast('Failed to follow user. Please try again.', 'error');
                    },
                    complete: function() {
                        button.prop('disabled', false);
                    }
                });
            });

            // Load more posts
            $('#loadMoreBtn').click(function() {
                const button = $(this);
                const page = button.data('page');
                const seed = button.data('seed');

                // Show loading state
                button.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span> Loading...');

                $.ajax({
                    url: '@Url.Action("LoadMorePosts", "Home")',
                    type: 'GET',
                    data: { page: page, seed: seed },
                    success: function(html) {
                        if (html.trim()) {
                            // Append new posts before the load more button
                            $('#postsContainer').append(html);

                            // Update page number
                            button.data('page', page + 1);
                        } else {
                            // No more posts to load
                            button.remove();
                            $('<p class="text-center text-muted mt-3">No more posts to load</p>').insertAfter('#loadMoreBtn');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error loading more posts:', error);
                        showToast('Failed to load more posts. Please try again.', 'error');
                        button.prop('disabled', false).html('<i class="bi bi-arrow-down"></i> Load More Posts');
                    },
                    complete: function() {
                        if (button.is(':visible')) {
                            button.prop('disabled', false).html('<i class="bi bi-arrow-down"></i> Load More Posts');
                        }
                    }
                });
            });

            // View all comments
            $(document).on('click', '.view-all-comments', function(e) {
                e.preventDefault();
                const postId = $(this).data('post-id');
                const postCard = $('#post-' + postId);
                const commentsSection = postCard.find('.comments-section');

                // Load all comments via AJAX
                $.ajax({
                    url: '@Url.Action("GetPostDetails", "Home")',
                    type: 'GET',
                    data: { postId: postId },
                    success: function(html) {
                        // Replace the comments section with the new one
                        commentsSection.replaceWith($(html).find('.comments-section'));
                    },
                    error: function(xhr, status, error) {
                        console.error('Error loading comments:', error);
                    }
                });
            });

            // Helper function to show toast messages
            function showToast(message, type = 'info') {
                // Create toast container if it doesn't exist
                if (!$('#toastContainer').length) {
                    $('body').append(`
                        <div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
                        </div>
                    `);
                }

                // Determine background color
                let bgColor = 'bg-primary';
                if (type === 'success') bgColor = 'bg-success';
                else if (type === 'error') bgColor = 'bg-danger';
                else if (type === 'warning') bgColor = 'bg-warning';

                // Create toast HTML
                const toastId = 'toast-' + Date.now();
                const toastHtml = `
                    <div id="${toastId}" class="toast ${bgColor} text-white" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                <i class="bi ${type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-exclamation-circle' : 'bi-info-circle'} me-2"></i>
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                `;

                // Add toast to container
                $('#toastContainer').append(toastHtml);

                // Show toast
                const toastElement = document.getElementById(toastId);
                const toast = new bootstrap.Toast(toastElement, {
                    delay: 3000
                });
                toast.show();

                // Remove toast after it's hidden
                toastElement.addEventListener('hidden.bs.toast', function () {
                    $(this).remove();
                });
            }
        });
    </script>
}