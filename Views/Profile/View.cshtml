@model semproject.Models.UserProfile
@{
    ViewData["Title"] = Model.User.UserName + "'s Profile";
    var isOwnProfile = ViewBag.CurrentUserId == Model.User.Id;
}

<div class="container mt-4">
    <!-- Profile Header -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 text-center">
                    <!-- Profile Picture (placeholder) -->
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                         style="width: 150px; height: 150px; margin: 0 auto; font-size: 48px; color: white;">
                        <i class="bi bi-person"></i>
                    </div>
                </div>
                <div class="col-md-9">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="mb-1">@Model.User.UserName</h2>
                            <p class="text-muted mb-0">@Model.User.Email</p>
                        </div>

                        @if (isOwnProfile)
                        {
                            <span class="badge bg-info">Your Profile</span>
                        }
                        else
                        {
                            <form asp-controller="Profile" asp-action="ToggleFollow" method="post">
                                <input type="hidden" name="followingId" value="@Model.User.Id" />

                                @if (Model.IsFollowing)
                                {
                                    <button type="submit" class="btn btn-outline-secondary">
                                        <i class="bi bi-person-check"></i> Following
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-person-plus"></i> Follow
                                    </button>
                                }
                            </form>
                        }
                    </div>

                    <!-- Stats -->
                    <div class="row text-center mt-4">
                        <div class="col-3">
                            <a asp-controller="Profile" asp-action="View" asp-route-id="@Model.User.Id#posts"
                               class="text-decoration-none">
                                <h4>@Model.PostCount</h4>
                                <small class="text-muted">Posts</small>
                            </a>
                        </div>
                        <div class="col-3">
                            <a asp-controller="Follow" asp-action="Followers" asp-route-userId="@Model.User.Id"
                               class="text-decoration-none">
                                <h4>@Model.FollowerCount</h4>
                                <small class="text-muted">Followers</small>
                            </a>
                        </div>
                        <div class="col-3">
                            <a asp-controller="Follow" asp-action="Following" asp-route-userId="@Model.User.Id"
                               class="text-decoration-none">
                                <h4>@Model.FollowingCount</h4>
                                <small class="text-muted">Following</small>
                            </a>
                        </div>
                        <div class="col-3">
                            <a asp-controller="Profile" asp-action="View" asp-route-id="@Model.User.Id#groups"
                               class="text-decoration-none">
                                <h4>@Model.GroupCount</h4>
                                <small class="text-muted">Groups</small>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Profile Tabs -->
    <ul class="nav nav-tabs mb-4" id="profileTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="posts-tab" data-bs-toggle="tab" data-bs-target="#posts" type="button">
                Posts (@Model.PostCount)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="groups-tab" data-bs-toggle="tab" data-bs-target="#groups" type="button">
                Groups (@Model.GroupCount)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="followers-tab" data-bs-toggle="tab" data-bs-target="#followers" type="button">
                Followers (@Model.FollowerCount)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="following-tab" data-bs-toggle="tab" data-bs-target="#following" type="button">
                Following (@Model.FollowingCount)
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="profileTabContent">
        <!-- Posts Tab -->
        <div class="tab-pane fade show active" id="posts" role="tabpanel">
            @if (Model.Posts.Any())
            {
                <div class="row">
                    @foreach (var post in Model.Posts)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h5 class="card-title mb-1">@Model.User.UserName</h5>
                                            <small class="text-muted">@post.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</small>
                                        </div>

                                        <!-- EDIT BUTTON - Only shows on user's own profile -->
                                        @if (isOwnProfile)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm edit-post-btn"
                                                    data-post-id="@post.Id">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>
                                        }
                                    </div>

                                    <p class="card-text post-content-@post.Id">@post.Content</p>

                                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                                    {
                                        <img src="@post.ImageUrl" class="img-fluid rounded mb-3" alt="Post image">
                                        @if (isOwnProfile)
                                        {
                                            <div class="alert alert-info small mb-3">
                                                <i class="bi bi-info-circle"></i> Image cannot be edited
                                            </div>
                                        }
                                    }

                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">
                                            <i class="bi bi-hand-thumbs-up"></i> @post.Likes.Count likes
                                        </span>
                                        <span class="text-muted">@post.Comments.Count comments</span>
                                    </div>

                                    <div class="mt-3">
                                        <a href="/Home/Feed#post-@post.Id" class="btn btn-outline-primary btn-sm">
                                            View Full Post
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <h4>No posts yet</h4>
                    <p class="text-muted">@Model.User.UserName hasn't created any posts</p>
                </div>
            }
        </div>

        <!-- Groups Tab -->
        <div class="tab-pane fade" id="groups" role="tabpanel">
            @if (Model.Groups.Any())
            {
                <div class="row">
                    @foreach (var group in Model.Groups)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">@group.Name</h5>
                                    <p class="card-text text-muted">@group.Description</p>

                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <i class="bi bi-people"></i> @group.Members.Count members
                                            @if (group.IsPrivate)
                                            {
                                                <span class="badge bg-secondary ms-2">Private</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success ms-2">Public</span>
                                            }
                                        </small>
                                        <a asp-controller="Groups" asp-action="Details" asp-route-id="@group.Id"
                                           class="btn btn-outline-primary btn-sm">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <h4>No groups yet</h4>
                    <p class="text-muted">@Model.User.UserName hasn't joined any groups</p>
                </div>
            }
        </div>

        <!-- Followers Tab -->
        <div class="tab-pane fade" id="followers" role="tabpanel">
            @if (Model.Followers.Any())
            {
                <div class="row">
                    @foreach (var follower in Model.Followers)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@follower.UserName</h6>
                                            <small class="text-muted">@follower.Email</small>
                                        </div>

                                        @if (follower.Id != ViewBag.CurrentUserId)
                                        {
                                            <form asp-controller="Follow" asp-action="ToggleFollow" method="post">
                                                <input type="hidden" name="followingId" value="@follower.Id" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                                                @if (await _followService.IsFollowingAsync(ViewBag.CurrentUserId, follower.Id))
                                                {
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                        <i class="bi bi-person-check"></i> Following
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-primary btn-sm">
                                                        <i class="bi bi-person-plus"></i> Follow
                                                    </button>
                                                }
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-3">
                    <a asp-controller="Follow" asp-action="Followers" asp-route-userId="@Model.User.Id"
                       class="btn btn-outline-primary">
                        View All Followers
                    </a>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <h4>No followers yet</h4>
                    <p class="text-muted">When someone follows @Model.User.UserName, they'll appear here</p>
                </div>
            }
        </div>

        <!-- Following Tab -->
        <div class="tab-pane fade" id="following" role="tabpanel">
            @if (Model.Following.Any())
            {
                <div class="row">
                    @foreach (var following in Model.Following)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@following.UserName</h6>
                                            <small class="text-muted">@following.Email</small>
                                        </div>

                                        @if (following.Id != ViewBag.CurrentUserId)
                                        {
                                            <form asp-controller="Follow" asp-action="ToggleFollow" method="post">
                                                <input type="hidden" name="followingId" value="@following.Id" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                                                @if (await _followService.IsFollowingAsync(ViewBag.CurrentUserId, following.Id))
                                                {
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                        <i class="bi bi-person-check"></i> Following
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-primary btn-sm">
                                                        <i class="bi bi-person-plus"></i> Follow
                                                    </button>
                                                }
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-3">
                    <a asp-controller="Follow" asp-action="Following" asp-route-userId="@Model.User.Id"
                       class="btn btn-outline-primary">
                        View All Following
                    </a>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <h4>Not following anyone yet</h4>
                    <p class="text-muted">When @Model.User.UserName follows someone, they'll appear here</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Container for edit modal -->
<div id="editModalContainer"></div>

@inject semproject.Services.Interfaces.IFollowService _followService

@section Scripts {
    <script>
        // Activate tab from URL hash
        document.addEventListener('DOMContentLoaded', function() {
            const hash = window.location.hash;
            if (hash) {
                const tab = document.querySelector(`button[data-bs-target="${hash}"]`);
                if (tab) {
                    new bootstrap.Tab(tab).show();
                }
            }

            // Load edit form when edit button is clicked
            $('.edit-post-btn').click(function() {
                var postId = $(this).data('post-id');

                // Clear previous modal content
                $('#editModalContainer').empty();

                // Load edit form via AJAX
                $.ajax({
                    url: '@Url.Action("EditPost", "Home")',
                    type: 'GET',
                    data: { postId: postId },
                    success: function(response) {
                        $('#editModalContainer').html(response);
                        $('#editPostModal').modal('show');
                    },
                    error: function(xhr, status, error) {
                        if (xhr.status === 403) {
                            alert('You are not authorized to edit this post.');
                        } else if (xhr.status === 404) {
                            alert('Post not found.');
                        } else {
                            alert('Error loading edit form.');
                        }
                    }
                });
            });
        });

        // Function to show toast notifications
        function showToast(message, type = 'success') {
            // Check if toast container exists
            if (!$('.toast-container').length) {
                $('body').append('<div class="toast-container position-fixed top-0 end-0 p-3"></div>');
            }

            const toastId = 'toast-' + Date.now();
            const toastHtml = `
                <div id="${toastId}" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="toast-header">
                        <strong class="me-auto">Notification</strong>
                        <small>just now</small>
                        <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                    <div class="toast-body">
                        ${message}
                    </div>
                </div>
            `;

            $('.toast-container').append(toastHtml);
            const toastElement = document.getElementById(toastId);
            const toast = new bootstrap.Toast(toastElement);
            toast.show();

            // Remove toast after it's hidden
            toastElement.addEventListener('hidden.bs.toast', function () {
                $(this).remove();
            });
        }
    </script>
}